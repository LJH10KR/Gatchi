rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users 컬렉션
    // - read: 로그인한 사용자는 다른 사용자 정보도 조회 가능 (동행자 이메일 검색 등)
    // - write: 각 사용자는 자신의 문서 및 하위 문서만 수정 가능
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // trips 및 하위 컬렉션(days, plans, checklists, requests 등)
    // - read: 모든 사용자가 가능 (공개 읽기)
    // - write: ownerUid 또는 members 배열에 포함된 사용자만 가능
    match /trips/{tripId} {
      // 하위 컬렉션은 상위 trip 문서의 ownerUid/members를 기준으로 권한 확인
      function canEditTrip() {
        return request.auth != null
               && (
                 request.auth.uid == get(/databases/$(database)/documents/trips/$(tripId)).data.ownerUid
                 || request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members
               );
      }

      // 읽기: 누구나 가능
      allow read: if true;

      // trip 문서 자체의 수정/삭제/생성도 canEditTrip 기준으로 허용
      allow update, delete: if canEditTrip();

      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      match /days/{dayId} {
        // 읽기: 누구나 가능
        allow read: if true;
        // 쓰기: 소유자 또는 동행자
        allow write: if canEditTrip();
      }

      match /days/{dayId}/plans/{planId} {
        allow read: if true;
        allow write: if canEditTrip();
      }

      match /checklists/{itemId} {
        allow read: if true;
        allow write: if canEditTrip();
      }

      match /requests/{requestId} {
        allow read: if true;
        allow create: if canEditTrip();
      }
    }
  }
}
